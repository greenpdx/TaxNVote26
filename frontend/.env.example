# Frontend build-time config. Copy to frontend/.env and edit.
# These must match the server's .env or rendered values will diverge from
# what the backend will accept.

VITE_FISCAL_YEAR=2027
VITE_BEA_FILTER=Discretionary
VITE_ON_BUDGET_ONLY=true

# Auth UI variant — MUST match the server build this SPA is bundled with:
#   full — email/password registration + login (permanent public site)
#   demo — name + 4-digit PIN identity (conference build; admin email login
#          remains available via the "Admin sign-in" toggle)
# Defaults to full when unset. The Docker build sets this from its VARIANT arg.
VITE_AUTH_MODE=full
