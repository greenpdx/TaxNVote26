# Frontend build-time config. Copy to frontend/.env and edit.
# These must match the server's .env or rendered values will diverge from
# what the backend will accept.

VITE_FISCAL_YEAR=2027
VITE_BEA_FILTER=Discretionary
VITE_ON_BUDGET_ONLY=true

# Sign-up coupon that unlocks the demo identity path (name + 4-digit PIN).
# The server must also have ENABLE_DEMO_IDENTITY=true for it to take effect.
VITE_DEMO_COUPON=ISDC2026
