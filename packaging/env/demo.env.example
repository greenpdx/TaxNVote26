# Tax N Vote — demo (conference, name + PIN). Copied to /etc/tnv/demo.env on
# install. Self-contained SQLite by default — no external database needed.
# Edit before starting the service.

# JWT signing key, >= 32 chars. Generate a FRESH one: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_openssl_rand_hex_32

# Self-contained SQLite (created on first start). Use a separate DB from the
# permanent site so demo submissions never mix with real data.
DATABASE_URL=sqlite:///var/lib/tnv/demo.db?mode=rwc

# Active fiscal year (4 digits). MUST match the SPA this package was built with.
FISCAL_YEAR=2027

# Runs on :3001 so it can sit alongside the full site on :3000.
BIND_ADDR=0.0.0.0:3001
STATIC_DIR=/opt/tnv/demo/static
DATA_DIR=/opt/tnv/data

# Set true ONLY when behind a reverse proxy that sets X-Forwarded-For.
TRUSTED_PROXY=false

RUST_LOG=info,tnv_server=info
