# Tax N Vote — full (permanent site). Copied to /etc/tnv/full.env on install.
# Edit before starting the service.

# JWT signing key, >= 32 chars. Generate a FRESH one: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_openssl_rand_hex_32

# Database. Postgres recommended for the permanent site; or self-contained SQLite:
#   DATABASE_URL=sqlite:///var/lib/tnv/full.db?mode=rwc
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/tnv

# Active fiscal year (4 digits). MUST match the SPA this package was built with.
FISCAL_YEAR=2027

BIND_ADDR=0.0.0.0:3000
STATIC_DIR=/opt/tnv/full/static
DATA_DIR=/opt/tnv/data

# Email verification for registration (full build). Empty SMTP_HOST = log-only.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@taxnvote.org

# Promote this (already-registered) account to admin on start.
BOOTSTRAP_ADMIN_EMAIL=

# Set true ONLY when behind a reverse proxy that sets X-Forwarded-For.
TRUSTED_PROXY=false

RUST_LOG=info,tnv_server=info
