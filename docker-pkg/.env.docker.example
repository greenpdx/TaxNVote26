# TNV website container environment — copy to .env.docker and edit.
# Holds secrets; provided to the container via docker-compose `env_file`.

# ─── Required ────────────────────────────────────────────────────────────────

# JWT signing key, >= 32 chars. Generate a FRESH one: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_openssl_rand_hex_32

# Postgres connection (the app does not run Postgres):
#   postgres://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=postgres://postgres:CHANGE_ME@10.1.42.27:5432/tnv

# Active fiscal year. The prebuilt SPA in this package is baked for 2027, so
# keep this 2027 unless you rebuild the frontend on a build-capable machine.
FISCAL_YEAR=2027

# ─── Recommended ─────────────────────────────────────────────────────────────

# Promote this (already-registered) account to admin on first start.
BOOTSTRAP_ADMIN_EMAIL=

# Email delivery for registration codes (empty SMTP_HOST = log-only).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@taxnvote.org

# ─── Optional tuning (defaults shown) ────────────────────────────────────────

# JWT_TTL_HOURS=2
# DB_MAX_CONNECTIONS=10
# REQUEST_TIMEOUT_SECS=30
# MAX_CONCURRENT_REQUESTS=1024

# PIN identity is a compile-time build variant now (VARIANT=demo), not a runtime
# flag. This packaged image is the `full` build; see DOCKER.md for the demo build.

# Same-origin by default; set only for a cross-origin frontend.
# ALLOWED_ORIGINS=

# Log filter. Do NOT enable tnv_server::mailer=debug in prod (logs codes).
RUST_LOG=info,tnv_server=info
