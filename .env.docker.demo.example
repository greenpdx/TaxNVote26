# TNV demo container environment — copy to .env.docker.demo and edit.
# .env.docker.demo is gitignored (it holds secrets). Provided to the container
# via docker-compose.demo.yml `env_file`.
#
# This is the conference build (name + 4-digit PIN identity). There is no public
# email registration, so SMTP is not needed; admin still signs in with email +
# password (bootstrap one below, or with `tnv-server admin create`).

# ─── Required ────────────────────────────────────────────────────────────────

# JWT signing key, >= 32 chars. Generate a FRESH one per environment:
#   openssl rand -hex 32
JWT_SECRET=CHANGE_ME_openssl_rand_hex_32

# Postgres connection. Use a SEPARATE database from the permanent site so demo
# submissions never mix with real data.
#   postgres://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=postgres://postgres:CHANGE_ME@10.1.42.27:5432/tnv_demo

# Active fiscal year (4 digits). MUST equal the compose FISCAL_YEAR build arg.
FISCAL_YEAR=2027

# ─── Recommended ─────────────────────────────────────────────────────────────

# Promote this (already-created) account to admin on first start. Create the
# account first with: docker compose -f docker-compose.demo.yml exec demo \
#   ./tnv-server admin create <email> <username> <password>
BOOTSTRAP_ADMIN_EMAIL=

# ─── Optional tuning (defaults shown) ────────────────────────────────────────

# JWT_TTL_HOURS=2
# DB_MAX_CONNECTIONS=10
# REQUEST_TIMEOUT_SECS=30
# MAX_CONCURRENT_REQUESTS=1024

# Demo PIN identity is mounted by this build. The admin can still toggle it off
# at runtime via the `demo_identity_enabled` setting in the admin Config tab.

# Same-origin by default (SPA served by this container behind the proxy). Set a
# comma-separated origin list only for a cross-origin frontend.
# ALLOWED_ORIGINS=

# Log filter.
RUST_LOG=info,tnv_server=info

# NOTE: TRUSTED_PROXY is set in docker-compose.demo.yml (true, because a reverse
# proxy fronts this container). Only correct when actually behind a trusted proxy.
