# TNV website container environment — copy to .env.docker and edit.
# .env.docker is gitignored (it holds secrets). Provided to the container via
# docker-compose `env_file`.

# ─── Required ────────────────────────────────────────────────────────────────

# JWT signing key, >= 32 chars. Generate a FRESH one per environment:
#   openssl rand -hex 32
JWT_SECRET=CHANGE_ME_openssl_rand_hex_32

# Postgres connection. Point at your database (the app does not run Postgres).
#   postgres://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=postgres://postgres:CHANGE_ME@10.1.42.27:5432/tnv

# Active fiscal year (4 digits). MUST equal the Dockerfile/compose FISCAL_YEAR
# build arg, or the SPA and server will disagree.
FISCAL_YEAR=2027

# ─── Recommended ─────────────────────────────────────────────────────────────

# Promote this (already-registered) account to admin on first start.
BOOTSTRAP_ADMIN_EMAIL=

# Email delivery for registration codes (leave SMTP_HOST empty to log-only).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@taxnvote.org

# ─── Optional tuning (defaults shown) ────────────────────────────────────────

# JWT_TTL_HOURS=2
# DB_MAX_CONNECTIONS=10
# REQUEST_TIMEOUT_SECS=30
# MAX_CONCURRENT_REQUESTS=1024

# Demo PIN identity endpoint — keep OFF in production (impersonation oracle).
# ENABLE_DEMO_IDENTITY=false

# Same-origin by default (SPA served by this container behind the proxy). Set a
# comma-separated origin list only for a cross-origin frontend.
# ALLOWED_ORIGINS=

# Log filter. Do NOT enable tnv_server::mailer=debug in prod (logs codes).
RUST_LOG=info,tnv_server=info

# NOTE: TRUSTED_PROXY is set in docker-compose.yml (true, because a reverse proxy
# fronts this container). Only correct when actually behind a trusted proxy.
