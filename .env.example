# TNV server configuration — copy this file to .env and edit for your environment.
# .env is gitignored; .env.example is committed.

# ─── Required ────────────────────────────────────────────────────────────────

# Signing key for JWTs. MUST be at least 32 chars. Generate with:
#   openssl rand -hex 32
JWT_SECRET=replace-me-with-output-of-openssl-rand-hex-32-must-be-32-chars-or-more

# Database connection string. Either sqlite or postgres is supported.
#   SQLite (file):  sqlite://data/tnv.db?mode=rwc
#   SQLite (mem):   sqlite::memory:
#   Postgres:       postgres://user:pass@host:5432/tnv
DATABASE_URL=sqlite://data/tnv.db?mode=rwc

# Fiscal year used for the embedded budget tree and as the default for
# template / tax-dollar submissions. Bumped each year on release.
FISCAL_YEAR=2027

# ─── Optional ────────────────────────────────────────────────────────────────

# Directory containing budauth.csv (required at startup).
DATA_DIR=data

# Listen address. Behind a reverse proxy, bind to 127.0.0.1:3000 so the
# plaintext port is not directly reachable.
BIND_ADDR=0.0.0.0:3000

# JWT lifetime in hours (default 2). Short-lived; tokens carry a jti and can be
# revoked, and disabling an account/person takes effect on the next request.
JWT_TTL_HOURS=2

# Database connection pool size (default 10).
DB_MAX_CONNECTIONS=10

# Per-request timeout in seconds (default 30) — slow-loris / hung-handler guard.
REQUEST_TIMEOUT_SECS=30

# Max in-flight requests before backpressure (default 1024).
MAX_CONCURRENT_REQUESTS=1024

# Promote this email account to admin on startup (one-time bootstrap). The
# account must already exist (register first); also available as the CLI
# `tnv-server admin promote <email>`.
BOOTSTRAP_ADMIN_EMAIL=

# Set to true ONLY when the app runs behind a trusted reverse proxy (e.g. Caddy)
# that sets X-Forwarded-For. When true, the client IP for rate limiting is taken
# from that header; otherwise it is the TCP peer. Never enable without a proxy —
# the header is client-spoofable.
TRUSTED_PROXY=false

# Demo PIN identity endpoint (/api/identify: name + 4-digit PIN). It is an
# impersonation oracle and MUST stay false in production. Off by default.
ENABLE_DEMO_IDENTITY=false

# SMTP for email verification. Leave SMTP_HOST empty to use the log-only mailer
# (dev mode — verification codes go to debug logs). When SMTP_HOST is set, mail
# is delivered over TLS (implicit TLS on port 465, STARTTLS otherwise) and a
# send failure makes registration fail rather than silently drop the code.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@taxnvote.org

# Logging filter (RUST_LOG syntax). Do NOT enable tnv_server::mailer=debug in
# production — it would write verification codes to logs.
RUST_LOG=info,tnv_server=debug
